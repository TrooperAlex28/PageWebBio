PORT=3000

# Destination pour recevoir les messages du formulaire
CONTACT_TO=recipient@example.com

# SMTP Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail-address@example.com
# Utiliser un mot de passe d'application Google (16 caracteres), pas le mot de passe du compte
SMTP_PASS=your-google-app-password

# Facultatif
CONTACT_FROM_NAME=Site WebBio
CONTACT_FROM_EMAIL=your-gmail-address@example.com
